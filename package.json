{
  "name": "task-manager-extension-v1",
  "displayName": "Task Manager Extension",
  "description": "A local workspace task manager built as a VS Code Webview extension.",
  "version": "0.9.5",
  "publisher": "local",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:taskManager.open",
    "onCommand:taskManager.swapDebugData",
    "onView:taskManager.tasksView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "taskManager",
          "title": "Task Manager",
          "icon": "media/task-manager-extension-icon.svg"
        }
      ]
    },
    "views": {
      "taskManager": [
        {
          "id": "taskManager.tasksView",
          "name": "Tasks",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "taskManager.open",
        "title": "Task Manager: Open"
      },
      {
        "command": "taskManager.swapDebugData",
        "title": "Task Manager: Swap Debug Data"
      }
    ],
    "keybindings": [
      {
        "command": "taskManager.swapDebugData",
        "key": "ctrl+alt+p"
      }
    ]
  },
  "scripts": {
    "compile": "npm run compile:extension && npm run typecheck:webview && npm run build:webview",
    "compile:extension": "tsc -p ./",
    "typecheck:webview": "tsc -p ./tsconfig.webview.json",
    "build:webview": "vite build",
    "package:vsix": "npm run compile && vsce package --allow-missing-repository --no-rewrite-relative-links --out task-manager-extension-v1-0.9.5.vsix",
    "publish:marketplace": "npm run compile && vsce publish",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@tiptap/extension-link": "^2.4.0",
    "@tiptap/pm": "^2.4.0",
    "@tiptap/react": "^2.4.0",
    "@tiptap/starter-kit": "^2.4.0",
    "@types/node": "^20.14.8",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vscode/vsce": "^3.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
